# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.fleet/

# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
out/
target/

# Tauri
apps/dashboard/src-tauri/target/
apps/dashboard/src-tauri/gen/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/
*.egg-info/

# Secrets — NEVER commit these
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
credentials.enc
**/master_credentials.enc
**/credentials.enc

# Per-client data — NEVER committed (lives only on operator's machine)
clients/*
!clients/.gitkeep

# Operator-level shared state — NEVER committed (API keys, caches with PII)
shared/*
!shared/.gitkeep

# Logs / runtime artifacts
*.log
logs/
launchd_*.log

# Database files (per-client SQLite, never committed)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# AI model weights / adapters (large files, distributed separately)
models/
lora_*/
*.safetensors
*.gguf

# OS temp / scratch
*.tmp
*.bak
*.orig
